        request.resource.data.lockMode == 'soft' &&
        request.resource.data.heartbeatAtMs is int &&
        request.resource.data.heartbeatAtMs > 0;

      allow delete: if isSignedIn() &&
        (
          request.auth.uid == resource.data.userId ||
          isSchoolManager(resource.data.schoolId)
        );
    }
  }
