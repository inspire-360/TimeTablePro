rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userProfileDoc(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function hasUserProfile() {
      return isSignedIn() && exists(userProfileDoc(request.auth.uid));
    }

    function currentUserProfile() {
      return get(userProfileDoc(request.auth.uid)).data;
    }

    function isPlatformAdmin() {
      return hasUserProfile() && currentUserProfile().role == 'super_admin';
    }

    function isSchoolMember(schoolId) {
      return hasUserProfile() &&
        (currentUserProfile().schoolId == schoolId || isPlatformAdmin());
    }

    function isSchoolManager(schoolId) {
      return isSchoolMember(schoolId) &&
        (
          currentUserProfile().role == 'super_admin' ||
          currentUserProfile().role == 'school_admin' ||
          currentUserProfile().role == 'academic_admin'
        );
    }

    function isNonEmptyString(value) {
      return value is string && value.size() > 0;
    }

    function isOptionalString(value) {
      return value == null || value is string;
    }

    function isStatus(value) {
      return value == 'active' || value == 'inactive';
    }

    function isOptionalPositiveInt(value) {
      return value == null || (value is int && value > 0);
    }

    function isOptionalNonNegativeInt(value) {
      return value == null || (value is int && value >= 0);
    }

    function isOptionalBool(value) {
      return value == null || value is bool;
    }

    function isSectionType(value) {
      return value == 'full_class' || value == 'subgroup';
    }

    function isTimetableType(value) {
      return value == 'class' || value == 'teacher' || value == 'room';
    }

    function isTimeSlotType(value) {
      return value == 'teaching' || value == 'break' || value == 'lunch';
    }

    function isPublicationStatus(value) {
      return value == 'draft' || value == 'published';
    }

    function isAbsenceStatus(value) {
      return value == 'reported' || value == 'approved' || value == 'cancelled';
    }

    function isSubstitutionStatus(value) {
      return value == 'assigned' || value == 'cancelled';
    }

    match /users/{userId} {
      allow create: if isSignedIn() &&
        userId == request.auth.uid &&
        request.resource.data.uid == request.auth.uid;

      allow read: if isSignedIn() &&
        (
          userId == request.auth.uid ||
          isPlatformAdmin() ||
          isSchoolManager(resource.data.schoolId)
        );

      allow update: if isSignedIn() &&
        (
          (userId == request.auth.uid &&
            request.resource.data.uid == resource.data.uid &&
            request.resource.data.schoolId == resource.data.schoolId) ||
          isPlatformAdmin()
        );

      allow delete: if false;
    }

    match /schools/{schoolId} {
      allow create: if isSchoolManager(request.resource.data.schoolId) &&
        request.resource.data.schoolId == schoolId;

      allow read: if isSchoolMember(schoolId);

      allow update: if isSchoolManager(schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId;

      allow delete: if false;
    }

    match /schoolSettings/{schoolId} {
      allow create, update: if isSchoolManager(request.resource.data.schoolId) &&
        request.resource.data.schoolId == schoolId;

      allow read: if isSchoolMember(schoolId);
      allow delete: if false;
    }

    match /academicYears/{academicYearId} {
      allow create: if isSchoolManager(request.resource.data.schoolId);

      allow read: if isSchoolMember(resource.data.schoolId);

      allow update: if isSchoolManager(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId;

      allow delete: if false;
    }

    match /terms/{termId} {
      allow create: if isSchoolManager(request.resource.data.schoolId);

      allow read: if isSchoolMember(resource.data.schoolId);

      allow update: if isSchoolManager(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId;

      allow delete: if false;
    }

    match /timeStructures/{timeStructureId} {
      allow create: if isSchoolManager(request.resource.data.schoolId) &&
        request.resource.data.daysPerWeek is int &&
        request.resource.data.daysPerWeek >= 1 &&
        request.resource.data.daysPerWeek <= 7 &&
        request.resource.data.periodsPerDay is int &&
        request.resource.data.periodsPerDay >= 1 &&
        request.resource.data.periodsPerDay <= 20 &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0;

      allow read: if isSchoolMember(resource.data.schoolId);

      allow update: if isSchoolManager(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        request.resource.data.daysPerWeek is int &&
        request.resource.data.daysPerWeek >= 1 &&
        request.resource.data.daysPerWeek <= 7 &&
        request.resource.data.periodsPerDay is int &&
        request.resource.data.periodsPerDay >= 1 &&
        request.resource.data.periodsPerDay <= 20 &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0;

      allow delete: if false;
    }

    match /dailySchedules/{dailyScheduleId} {
      allow create: if isSchoolManager(request.resource.data.schoolId) &&
        request.resource.data.weekdayOrder is int &&
        request.resource.data.weekdayOrder >= 1 &&
        request.resource.data.weekdayOrder <= 7 &&
        request.resource.data.slotCount is int &&
        request.resource.data.slotCount >= 0 &&
        request.resource.data.teachingSlotCount is int &&
        request.resource.data.teachingSlotCount >= 0;

      allow read: if isSchoolMember(resource.data.schoolId);

      allow update: if isSchoolManager(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        request.resource.data.timeStructureId == resource.data.timeStructureId &&
        request.resource.data.weekdayOrder is int &&
        request.resource.data.weekdayOrder >= 1 &&
        request.resource.data.weekdayOrder <= 7 &&
        request.resource.data.slotCount is int &&
        request.resource.data.slotCount >= 0 &&
        request.resource.data.teachingSlotCount is int &&
        request.resource.data.teachingSlotCount >= 0;

      allow delete: if false;
    }

    match /timeSlots/{timeSlotId} {
      allow create: if isSchoolManager(request.resource.data.schoolId) &&
        request.resource.data.slotIndex is int &&
        request.resource.data.slotIndex >= 1 &&
        request.resource.data.weekdayOrder is int &&
        request.resource.data.weekdayOrder >= 1 &&
        request.resource.data.weekdayOrder <= 7 &&
        request.resource.data.startTime is string &&
        request.resource.data.endTime is string &&
        request.resource.data.startTime < request.resource.data.endTime &&
        (
          request.resource.data.slotType == 'teaching' ||
          request.resource.data.slotType == 'break' ||
          request.resource.data.slotType == 'lunch'
        );

      allow read: if isSchoolMember(resource.data.schoolId);

      allow update: if isSchoolManager(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        request.resource.data.timeStructureId == resource.data.timeStructureId &&
        request.resource.data.dailyScheduleId == resource.data.dailyScheduleId &&
        request.resource.data.slotIndex is int &&
        request.resource.data.slotIndex >= 1 &&
        request.resource.data.weekdayOrder is int &&
        request.resource.data.weekdayOrder >= 1 &&
        request.resource.data.weekdayOrder <= 7 &&
        request.resource.data.startTime is string &&
        request.resource.data.endTime is string &&
        request.resource.data.startTime < request.resource.data.endTime &&
        (
          request.resource.data.slotType == 'teaching' ||
          request.resource.data.slotType == 'break' ||
          request.resource.data.slotType == 'lunch'
        );

      allow delete: if isSchoolManager(resource.data.schoolId);
    }

    match /plcPolicies/{plcPolicyId} {
      allow create: if isSchoolManager(request.resource.data.schoolId) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.timeStructureId is string &&
        request.resource.data.timeStructureId.size() > 0 &&
        request.resource.data.plcDays is list &&
        request.resource.data.plcDays.size() > 0 &&
        request.resource.data.plcDays.size() <= 7 &&
        request.resource.data.hoursPerWeek is number &&
        request.resource.data.hoursPerWeek > 0 &&
        request.resource.data.hoursPerWeek <= 20 &&
        request.resource.data.applyAfterLastTeaching == true &&
        request.resource.data.blocksTeacherTime == true &&
        request.resource.data.visibleInStudentTimetable == false;

      allow read: if isSchoolMember(resource.data.schoolId);

      allow update: if isSchoolManager(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.timeStructureId is string &&
        request.resource.data.timeStructureId.size() > 0 &&
        request.resource.data.plcDays is list &&
        request.resource.data.plcDays.size() > 0 &&
        request.resource.data.plcDays.size() <= 7 &&
        request.resource.data.hoursPerWeek is number &&
        request.resource.data.hoursPerWeek > 0 &&
        request.resource.data.hoursPerWeek <= 20 &&
        request.resource.data.applyAfterLastTeaching == true &&
        request.resource.data.blocksTeacherTime == true &&
        request.resource.data.visibleInStudentTimetable == false;

      allow delete: if false;
    }

    match /teacherWorkloadPolicies/{teacherWorkloadPolicyId} {
      allow create: if isSchoolManager(request.resource.data.schoolId) &&
        request.resource.data.teacherId is string &&
        request.resource.data.teacherId.size() > 0 &&
        request.resource.data.teacherName is string &&
        request.resource.data.teacherName.size() > 0 &&
        request.resource.data.plcEnabled is bool &&
        request.resource.data.plcDayOverrides is list &&
        request.resource.data.plcDayOverrides.size() <= 7 &&
        (
          request.resource.data.plcHoursPerWeekOverride == null ||
          (
            request.resource.data.plcHoursPerWeekOverride is number &&
            request.resource.data.plcHoursPerWeekOverride > 0 &&
            request.resource.data.plcHoursPerWeekOverride <= 20
          )
        );

      allow read: if isSchoolManager(resource.data.schoolId) ||
        (isSignedIn() && request.auth.uid == resource.data.teacherId);

      allow update: if isSchoolManager(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        request.resource.data.teacherId == resource.data.teacherId &&
        request.resource.data.teacherName is string &&
        request.resource.data.teacherName.size() > 0 &&
        request.resource.data.plcEnabled is bool &&
        request.resource.data.plcDayOverrides is list &&
        request.resource.data.plcDayOverrides.size() <= 7 &&
        (
          request.resource.data.plcHoursPerWeekOverride == null ||
          (
            request.resource.data.plcHoursPerWeekOverride is number &&
            request.resource.data.plcHoursPerWeekOverride > 0 &&
            request.resource.data.plcHoursPerWeekOverride <= 20
          )
        );

      allow delete: if false;
    }

    match /teacherPlcAssignments/{teacherPlcAssignmentId} {
      allow create: if isSchoolManager(request.resource.data.schoolId) &&
        request.resource.data.teacherId is string &&
        request.resource.data.teacherId.size() > 0 &&
        request.resource.data.plcPolicyId is string &&
        request.resource.data.plcPolicyId.size() > 0 &&
        request.resource.data.timeStructureId is string &&
        request.resource.data.timeStructureId.size() > 0 &&
        request.resource.data.weekdayOrder is int &&
        request.resource.data.weekdayOrder >= 1 &&
        request.resource.data.weekdayOrder <= 7 &&
        request.resource.data.startTime is string &&
        request.resource.data.endTime is string &&
        request.resource.data.startTime < request.resource.data.endTime &&
        request.resource.data.durationMinutes is int &&
        request.resource.data.durationMinutes > 0 &&
        request.resource.data.blocksTeacherTime == true &&
        request.resource.data.visibleInStudentTimetable == false &&
        (
          request.resource.data.source == 'policy' ||
          request.resource.data.source == 'teacher_override'
        );

      allow read: if isSchoolManager(resource.data.schoolId) ||
        (isSignedIn() && request.auth.uid == resource.data.teacherId);

      allow update: if isSchoolManager(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        request.resource.data.teacherId == resource.data.teacherId &&
        request.resource.data.plcPolicyId is string &&
        request.resource.data.plcPolicyId.size() > 0 &&
        request.resource.data.timeStructureId is string &&
        request.resource.data.timeStructureId.size() > 0 &&
        request.resource.data.weekdayOrder is int &&
        request.resource.data.weekdayOrder >= 1 &&
        request.resource.data.weekdayOrder <= 7 &&
        request.resource.data.startTime is string &&
        request.resource.data.endTime is string &&
        request.resource.data.startTime < request.resource.data.endTime &&
        request.resource.data.durationMinutes is int &&
        request.resource.data.durationMinutes > 0 &&
        request.resource.data.blocksTeacherTime == true &&
        request.resource.data.visibleInStudentTimetable == false &&
        (
          request.resource.data.source == 'policy' ||
          request.resource.data.source == 'teacher_override'
        );

      allow delete: if isSchoolManager(resource.data.schoolId);
    }

    match /learningAreas/{learningAreaId} {
      allow create: if isSchoolManager(request.resource.data.schoolId) &&
        isNonEmptyString(request.resource.data.code) &&
        isNonEmptyString(request.resource.data.name) &&
        isOptionalString(request.resource.data.description) &&
        isNonEmptyString(request.resource.data.colorToken) &&
        isNonEmptyString(request.resource.data.colorHex) &&
        request.resource.data.sortOrder is int &&
        request.resource.data.sortOrder >= 0 &&
        isStatus(request.resource.data.status);

      allow read: if isSchoolMember(resource.data.schoolId);

      allow update: if isSchoolManager(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        isNonEmptyString(request.resource.data.code) &&
        isNonEmptyString(request.resource.data.name) &&
        isOptionalString(request.resource.data.description) &&
        isNonEmptyString(request.resource.data.colorToken) &&
        isNonEmptyString(request.resource.data.colorHex) &&
        request.resource.data.sortOrder is int &&
        request.resource.data.sortOrder >= 0 &&
        isStatus(request.resource.data.status);

      allow delete: if isSchoolManager(resource.data.schoolId);
    }

    match /subjects/{subjectId} {
      allow create: if isSchoolManager(request.resource.data.schoolId) &&
        isNonEmptyString(request.resource.data.code) &&
        isNonEmptyString(request.resource.data.name) &&
        isOptionalString(request.resource.data.shortName) &&
        isNonEmptyString(request.resource.data.learningAreaId) &&
        isNonEmptyString(request.resource.data.learningAreaName) &&
        (
          request.resource.data.subjectType == 'core' ||
          request.resource.data.subjectType == 'elective'
        ) &&
        isNonEmptyString(request.resource.data.colorToken) &&
        isNonEmptyString(request.resource.data.colorHex) &&
        isStatus(request.resource.data.status);

      allow read: if isSchoolMember(resource.data.schoolId);

      allow update: if isSchoolManager(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        isNonEmptyString(request.resource.data.code) &&
        isNonEmptyString(request.resource.data.name) &&
        isOptionalString(request.resource.data.shortName) &&
        isNonEmptyString(request.resource.data.learningAreaId) &&
        isNonEmptyString(request.resource.data.learningAreaName) &&
        (
          request.resource.data.subjectType == 'core' ||
          request.resource.data.subjectType == 'elective'
        ) &&
        isNonEmptyString(request.resource.data.colorToken) &&
        isNonEmptyString(request.resource.data.colorHex) &&
        isStatus(request.resource.data.status);

      allow delete: if isSchoolManager(resource.data.schoolId);
    }

    match /teachers/{teacherId} {
      allow create: if isSchoolManager(request.resource.data.schoolId) &&
        isNonEmptyString(request.resource.data.employeeCode) &&
        isOptionalString(request.resource.data.title) &&
        isNonEmptyString(request.resource.data.firstName) &&
        isNonEmptyString(request.resource.data.lastName) &&
        isNonEmptyString(request.resource.data.displayName) &&
        isOptionalString(request.resource.data.email) &&
        isOptionalString(request.resource.data.phone) &&
        isStatus(request.resource.data.status);

      allow read: if isSchoolMember(resource.data.schoolId);

      allow update: if isSchoolManager(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        isNonEmptyString(request.resource.data.employeeCode) &&
        isOptionalString(request.resource.data.title) &&
        isNonEmptyString(request.resource.data.firstName) &&
        isNonEmptyString(request.resource.data.lastName) &&
        isNonEmptyString(request.resource.data.displayName) &&
        isOptionalString(request.resource.data.email) &&
        isOptionalString(request.resource.data.phone) &&
        isStatus(request.resource.data.status);

      allow delete: if isSchoolManager(resource.data.schoolId);
    }

    match /students/{studentId} {
      allow create: if isSchoolManager(request.resource.data.schoolId) &&
        isNonEmptyString(request.resource.data.studentCode) &&
        isOptionalString(request.resource.data.title) &&
        isNonEmptyString(request.resource.data.firstName) &&
        isNonEmptyString(request.resource.data.lastName) &&
        isNonEmptyString(request.resource.data.displayName) &&
        isNonEmptyString(request.resource.data.classId) &&
        isNonEmptyString(request.resource.data.className) &&
        isOptionalPositiveInt(request.resource.data.studentNumber) &&
        isStatus(request.resource.data.status);

      allow read: if isSchoolMember(resource.data.schoolId);

      allow update: if isSchoolManager(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        isNonEmptyString(request.resource.data.studentCode) &&
        isOptionalString(request.resource.data.title) &&
        isNonEmptyString(request.resource.data.firstName) &&
        isNonEmptyString(request.resource.data.lastName) &&
        isNonEmptyString(request.resource.data.displayName) &&
        isNonEmptyString(request.resource.data.classId) &&
        isNonEmptyString(request.resource.data.className) &&
        isOptionalPositiveInt(request.resource.data.studentNumber) &&
        isStatus(request.resource.data.status);

      allow delete: if isSchoolManager(resource.data.schoolId);
    }

    match /classes/{classId} {
      allow create: if isSchoolManager(request.resource.data.schoolId) &&
        isNonEmptyString(request.resource.data.code) &&
        isNonEmptyString(request.resource.data.name) &&
        isNonEmptyString(request.resource.data.gradeLevel) &&
        isOptionalString(request.resource.data.roomLabel) &&
        isOptionalString(request.resource.data.homeRoomTeacherId) &&
        isOptionalString(request.resource.data.homeRoomTeacherName) &&
        isStatus(request.resource.data.status);

      allow read: if isSchoolMember(resource.data.schoolId);

      allow update: if isSchoolManager(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        isNonEmptyString(request.resource.data.code) &&
        isNonEmptyString(request.resource.data.name) &&
        isNonEmptyString(request.resource.data.gradeLevel) &&
        isOptionalString(request.resource.data.roomLabel) &&
        isOptionalString(request.resource.data.homeRoomTeacherId) &&
        isOptionalString(request.resource.data.homeRoomTeacherName) &&
        isStatus(request.resource.data.status);

      allow delete: if isSchoolManager(resource.data.schoolId);
    }

    match /classrooms/{classroomId} {
      allow create: if isSchoolManager(request.resource.data.schoolId) &&
        isNonEmptyString(request.resource.data.code) &&
        isNonEmptyString(request.resource.data.name) &&
        isOptionalString(request.resource.data.building) &&
        isOptionalString(request.resource.data.floor) &&
        isOptionalPositiveInt(request.resource.data.capacity) &&
        isStatus(request.resource.data.status);

      allow read: if isSchoolMember(resource.data.schoolId);

      allow update: if isSchoolManager(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        isNonEmptyString(request.resource.data.code) &&
        isNonEmptyString(request.resource.data.name) &&
        isOptionalString(request.resource.data.building) &&
        isOptionalString(request.resource.data.floor) &&
        isOptionalPositiveInt(request.resource.data.capacity) &&
        isStatus(request.resource.data.status);

      allow delete: if isSchoolManager(resource.data.schoolId);
    }

    match /activities/{activityId} {
      allow create: if isSchoolManager(request.resource.data.schoolId) &&
        isNonEmptyString(request.resource.data.code) &&
        isNonEmptyString(request.resource.data.name) &&
        isNonEmptyString(request.resource.data.category) &&
        isOptionalString(request.resource.data.description) &&
        isStatus(request.resource.data.status);

      allow read: if isSchoolMember(resource.data.schoolId);

      allow update: if isSchoolManager(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        isNonEmptyString(request.resource.data.code) &&
        isNonEmptyString(request.resource.data.name) &&
        isNonEmptyString(request.resource.data.category) &&
        isOptionalString(request.resource.data.description) &&
        isStatus(request.resource.data.status);

      allow delete: if isSchoolManager(resource.data.schoolId);
    }

    match /classOfferings/{classOfferingId} {
      allow create: if isSchoolManager(request.resource.data.schoolId) &&
        isNonEmptyString(request.resource.data.classId) &&
        isNonEmptyString(request.resource.data.className) &&
        isNonEmptyString(request.resource.data.subjectId) &&
        isNonEmptyString(request.resource.data.subjectName) &&
        isStatus(request.resource.data.status);

      allow read: if isSchoolMember(resource.data.schoolId);

      allow update: if isSchoolManager(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        request.resource.data.classId == resource.data.classId &&
        request.resource.data.subjectId == resource.data.subjectId &&
        isNonEmptyString(request.resource.data.className) &&
        isNonEmptyString(request.resource.data.subjectName) &&
        isStatus(request.resource.data.status);

      allow delete: if isSchoolManager(resource.data.schoolId);
    }

    match /sections/{sectionId} {
      allow create: if isSchoolManager(request.resource.data.schoolId) &&
        isNonEmptyString(request.resource.data.classOfferingId) &&
        isNonEmptyString(request.resource.data.classId) &&
        isNonEmptyString(request.resource.data.subjectId) &&
        isSectionType(request.resource.data.sectionType) &&
        isNonEmptyString(request.resource.data.code) &&
        isNonEmptyString(request.resource.data.name) &&
        isOptionalString(request.resource.data.subgroupLabel) &&
        request.resource.data.sortOrder is int &&
        request.resource.data.sortOrder >= 1 &&
        request.resource.data.isDefault is bool &&
        isStatus(request.resource.data.status);

      allow read: if isSchoolMember(resource.data.schoolId);

      allow update: if isSchoolManager(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        request.resource.data.classOfferingId == resource.data.classOfferingId &&
        request.resource.data.classId == resource.data.classId &&
        request.resource.data.subjectId == resource.data.subjectId &&
        isSectionType(request.resource.data.sectionType) &&
        isNonEmptyString(request.resource.data.code) &&
        isNonEmptyString(request.resource.data.name) &&
        isOptionalString(request.resource.data.subgroupLabel) &&
        request.resource.data.sortOrder is int &&
        request.resource.data.sortOrder >= 1 &&
        request.resource.data.isDefault is bool &&
        isStatus(request.resource.data.status);

      allow delete: if isSchoolManager(resource.data.schoolId);
    }

    match /courseAssignments/{courseAssignmentId} {
      allow create: if isSchoolManager(request.resource.data.schoolId) &&
        isNonEmptyString(request.resource.data.classOfferingId) &&
        isNonEmptyString(request.resource.data.sectionId) &&
        isNonEmptyString(request.resource.data.classId) &&
        isNonEmptyString(request.resource.data.subjectId) &&
        isNonEmptyString(request.resource.data.teacherId) &&
        isNonEmptyString(request.resource.data.teacherName) &&
        isSectionType(request.resource.data.sectionType) &&
        isNonEmptyString(request.resource.data.sectionName) &&
        request.resource.data.sectionSortOrder is int &&
        request.resource.data.sectionSortOrder >= 1 &&
        request.resource.data.assignmentRole == 'subject_teacher' &&
        isStatus(request.resource.data.status);

      allow read: if isSchoolMember(resource.data.schoolId);

      allow update: if isSchoolManager(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId &&
        request.resource.data.classOfferingId == resource.data.classOfferingId &&
        request.resource.data.sectionId == resource.data.sectionId &&
        request.resource.data.classId == resource.data.classId &&
        request.resource.data.subjectId == resource.data.subjectId &&
        request.resource.data.teacherId == resource.data.teacherId &&
        isNonEmptyString(request.resource.data.teacherName) &&
        isSectionType(request.resource.data.sectionType) &&
        isNonEmptyString(request.resource.data.sectionName) &&
        request.resource.data.sectionSortOrder is int &&
        request.resource.data.sectionSortOrder >= 1 &&
        request.resource.data.assignmentRole == 'subject_teacher' &&
        isStatus(request.resource.data.status);

      allow delete: if isSchoolManager(resource.data.schoolId);
    }

